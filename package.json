{
    "name": "@particle-academy/classroom",
    "version": "0.1.1",
    "description": "Classroom UX — course-taking and testing surface for the laravel-courses API, built on Fancy UI primitives.",
    "keywords": [
        "courses",
        "classroom",
        "lms",
        "react",
        "tailwind",
        "particle-academy"
    ],
    "homepage": "https://github.com/Particle-Academy/classroom",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Particle-Academy/classroom.git"
    },
    "bugs": "https://github.com/Particle-Academy/classroom/issues",
    "license": "MIT",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "tsc --noEmit",
        "clean": "rm -rf dist",
        "prepublishOnly": "tsup"
    },
    "peerDependencies": {
        "@particle-academy/react-fancy": ">=3",
        "axios": ">=1",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@particle-academy/react-fancy": "^3.4.3",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "axios": "^1.11.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.7.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
