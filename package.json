{
    "name": "@particle-academy/classroom",
    "version": "0.0.1",
    "description": "Classroom UX — course-taking and testing surface for the laravel-courses API, built strictly on Fancy UI primitives.",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        }
    },
    "files": [
        "src",
        "README.md"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Particle-Academy/classroom.git"
    },
    "homepage": "https://github.com/Particle-Academy/classroom#readme",
    "bugs": {
        "url": "https://github.com/Particle-Academy/classroom/issues"
    },
    "peerDependencies": {
        "@particle-academy/react-fancy": ">=0",
        "axios": ">=1",
        "react": ">=18",
        "react-dom": ">=18"
    },
    "_notes": "Part of the Fancy UI kit. Source-only package: host apps consume ./src directly (via alias or a sibling checkout) and bundle it. Publish to npm from here when ready."
}
